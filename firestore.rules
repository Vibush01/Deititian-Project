rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated and is an admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    // 1. adminUsers collection
    // - Only logged-in users can read (to check if they are admin)
    // - NO ONE can write from the client (admins must be added manually via Firebase Console)
    match /adminUsers/{userId} {
      allow read: if request.auth != null;
      allow write: if false; 
    }

    // 2. inquiries collection
    // - Anyone can create a new inquiry (public contact form)
    // - Only admins can read, update, or delete inquiries
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // 3. All other content collections (siteSettings, pages, team, experts, recipes, etc.)
    // - Anyone can read (for the public website)
    // - Only admins can write (create, update, delete)
    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
